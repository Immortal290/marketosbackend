NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketos?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=marketos-backend

# Auth
JWT_SECRET=super_secret_jwt_key_for_development_only
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=super_secret_refresh_key_for_development_only
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://digitalmarketingagent-production.up.railway.app,http://localhost:5500,http://127.0.0.1:5500
