# ─── MarketOS Docker Compose Environment ─────────────────────────────────────
# Copy this to .env and update values for your environment.
# DO NOT commit real secrets to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketos

# JWT Auth
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Frontend origins allowed to hit the API
# Locally: frontend container is on port 8080
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
