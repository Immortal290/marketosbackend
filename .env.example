# ─── MarketOS Docker Compose Environment ─────────────────────────────────────
# Copy this to .env and update values for your environment.
# DO NOT commit real secrets to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketos

# JWT Auth
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Frontend origins allowed to hit the API
# Locally: frontend container is on port 8080
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | anthropic | openrouter | glm
LLM_PROVIDER=gemini

# GLM-5.2 via NVIDIA Integrate API (orchestration head)
# Get your key at: https://integrate.api.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# Other LLM keys (set whichever matches LLM_PROVIDER)
# GEMINI_API_KEY=your_gemini_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here
